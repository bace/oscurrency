<% member = Membership.mem(exchange.worker,exchange.group) %>
<li>
  <div class="row">
  <div class="col-xs-3 col-sm-1">
    <%= image_link exchange.worker, :link => member, :link_options => {:class => "show-follow"}, :image_options => {:class => "photo"}, :image => :thumbnail %>
  </div>
    <div class="col-xs-9 col-sm-11 member-content">
      <p>
  <% unless exchange.group.nil? %>
      <%= image_tag "icons/switch.gif", :class => "icon", :alt => "Street Cred" %>
      <%= membership_link member, :class => "url fn show-follow" %> <%= t('earned') + " " + nice_decimal(exchange.amount) + " " + exchange.group.unit.pluralize + " " + t('for') %> <%= link_to h(exchange&.metadata&.name), exchange.metadata, :class => "show-follow" %>
  <%- end -%>
      </p>
      <p class="meta published">
        <%= t( 'ago_time', :date=> time_ago_in_words(exchange.created_at)).capitalize %> 
      </p>
    </div>
  </div>
</li>
