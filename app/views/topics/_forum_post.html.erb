<li class="forum_post post_id_<%= forum_post.id %>" data-time="<%= forum_post.created_at.to_i %>">
  <div class="row">
    <a name="post_<%= forum_post.id %>"></a>
    <div class="col-xs-3 col-sm-1">
      <%= image_link forum_post.person, :image => :thumbnail %>
    </div>
    <div class="col-xs-9 col-sm-11 member-content">
      <p class="meta">
        <%= image_tag "icons/comment.gif", :class => "icon" %>
        <%= person_link forum_post.person %> <%= t('posted') %>
        <%= t('ago_time', :date => time_ago_in_words(forum_post.created_at)) %>
        <%- if can? :destroy, forum_post -%>
              <%= link_to t('button_delete'),forum_topic_post_path(@forum, @topic, forum_post),:class => 'delete_post' %>
        <%- end -%>
      </p>
      <div class="forum">
      <%= markdown(forum_post.body) %>
      </div>
    </div>
  </div>
</li>
