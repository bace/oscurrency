  <%- if global_prefs.app_name.blank? -%>
  <h2><%= t('people.new.header') %></h2>
  <%- else -%>
  <h2><%= t('people.new.header') %> <%= t('for') %> <%= global_prefs.app_name %></h2>
  <%- end -%>

  <%= display global_prefs.registration_intro %>
  <%= bootstrap_form_for @person, :help => :block, :html => {:class => 'form-horizontal'} do |f| -%>
<div class="row">
<div class="col-sm-6">
  <div class="form-group language-select">
    <%= f.label :language, t('people._language.language'), class: 'control-label col-sm-3' %>
    <div class="col-sm-9">
      <%= f.select :language, [[t('people._language.english'),'en'],[t('people._language.spanish'),'es'],[t('people._language.french'),'fr'],[t('people._language.greek'),'gr']], {:selected => params[:locale], :hide_label => true}, {:onchange => "document.location='/signup?locale=' + this.value"} %>
    </div>
  </div>
  <fieldset id="creds">
<span id="standard">
    <div class="form-group">
      <%= f.label :email, t('people.new.email_address'), class: 'control-label col-sm-3' %>
      <div class="col-sm-9">
        <%= f.email_field :email, hide_label: true, help: email_help %>
        <%= set_focus_to "person_email" %>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :name, t('people.new.name'), class: 'control-label col-sm-3' %>
      <div class="col-sm-9">
        <%= f.text_field :name, hide_label: true, help: t('people.new.will_be_displayed'), maxlength: Person::MAX_NAME %>
      </div>
    </div>

  <% if @person.openid_identifier.blank? %>
    <div class="form-group">
      <%= f.label :password, t('people.new.password'), class: 'control-label col-sm-3' %>
      <div class="col-sm-9">
        <%= f.password_field :password, hide_label: true, maxlength: Person::MAX_PASSWORD %>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, t('people.new.confirm_password'), class: 'control-label col-sm-3' %>
      <div class="col-sm-9">
        <%= f.password_field :password_confirmation, hide_label: true, maxlength: Person::MAX_PASSWORD, value: "" %>
      </div>
    </div>
  <%- end -%>
</span>

<span id="openid">
    <div class="form-group">
      <%= f.label :openid_identifier, t('people.new.openid_url'), class: 'control-label col-sm-3' %>
      <div class="col-sm-9">
        <%= f.text_field :openid_identifier, hide_label: true %>
      </div>
    </div>
</span>
</fieldset>

  <% if global_prefs.openid? %>
    <div style="text-align: center; font-size: 12px; padding: 10px;">
      <span id="noscript" style="display:none;">
        <span id="openid_link"><a href="#" onclick="show_openid(); return false;"><%= t('people.new.or_signup_with_openid') %></a></span>
        <span id="standard_link"><a href="#" onclick="show_standard(); return false;"><%= t('people.new.back_to_regular_signup') %></a></span>
      </span>
    </div>
  <% end %>
  <div class="form-group">
    <%= f.label t('people.new.which_services'), :class => 'control-label col-sm-3' %>
    <div class="controls col-sm-9">
      <%= render :partial => "shared/select_categories", :locals => { :model_name => 'person' } %>
    </div>
  </div>
</div>
<div class="col-sm-6">
  <div class="form-group description-text-area">
    <%= f.label :description, t('people.new.something_about_yourself'), class: 'control-label col-sm-3' %>
    <div class="col-sm-9" style="padding-top: 10px;">
      <%= f.text_area :description, rows: 6, hide_label: true %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label t('people.new.neighborhood'), :class => 'control-label col-sm-3' %>
    <div class="controls col-sm-9">
      <%= render :partial => "shared/select_neighborhoods", :locals => { :model_name => 'person' } %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :zipcode, t('people.new.zipcode'), class: 'control-label col-sm-3' %>
    <div class="col-sm-9 zipcode-field">
      <%= f.text_field :zipcode, hide_label: true %>
    </div>
  </div>

    <%= f.check_box :org, label: t('people.new.business_account') %>
    <div id="business_info">
        <div class="form-group">
          <%= f.label :business_name, t('people.edit.business_name'), class: 'control-label col-sm-3' %>
          <div class="col-sm-9">
            <%= f.text_field :business_name, hide_label: true %>
          </div>
        </div>
        <div class="form-group">
          <%= f.label t('people.edit.business_type'), :class => 'control-label col-sm-3' %>
          <div class="controls col-sm-9">
            <%= render :partial => "shared/select_business_type", :locals => { :model_name => 'person' } %>
          </div>
        </div>
    </div>
    <div class="form-group">
      <div class="controls" style="padding-left: 35px;">
        <label class="checkbox" for="person_accept_agreement">
          <input name="person[accept_agreement]" type="hidden" value="0" />
          <input type="checkbox" value="1" name="person[accept_agreement]" id="person_accept_agreement" /> <%= t('people.new.i_accept_the') %> <a target="_blank" class="small" href="/agreement"><%= t('people.new.member_agreeement') %></a>
        </label>
      </div>
    </div>

    <div class="form-group">
      <div class="col-sm-offset-3 col-sm-9">
        <%= f.primary t('people.new.signup_button') %>
      </div>
    </div>
</div>
</div>
  <% end %>
